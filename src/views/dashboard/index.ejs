<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="welcome">
    <h1>Tableau de bord</h1>
    <p>
      Utilisateur connecte: <strong><%= currentUser.username %></strong>
      (<%= currentUser.email %>)
    </p>
    <p>Date du jour: <strong><%= today.toLocaleDateString('fr-FR') %></strong></p>
  </section>

  <section class="panel">
    <h2>Reservations en cours</h2>
    <% if (!activeReservations.length) { %>
      <p>Aucune reservation active actuellement.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Catway</th>
            <th>Client</th>
            <th>Bateau</th>
            <th>Debut</th>
            <th>Fin</th>
          </tr>
        </thead>
        <tbody>
          <% activeReservations.forEach((reservation) => { %>
            <tr>
              <td><%= reservation.catwayNumber %></td>
              <td><%= reservation.clientName %></td>
              <td><%= reservation.boatName %></td>
              <td><%= new Date(reservation.startDate).toLocaleDateString('fr-FR') %></td>
              <td><%= new Date(reservation.endDate).toLocaleDateString('fr-FR') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>
